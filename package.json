{
  "name": "kitten",
  "version": "0.0.0",
  "description": "Kitten - Cross-Agent Hand-off Cockpit: a terminal cockpit that hands a live coding task between AI agents over ACP.",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "kitten": "src/index.ts"
  },
  "files": [
    "src",
    "bunfig.toml",
    "tsconfig.json"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "selfcheck": "bun run src/index.ts --self-check",
    "build": "bun run scripts/build.ts",
    "build:local": "bun build --compile ./src/index.ts --outfile kitten"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "1.2.1",
    "@opentui/core": "0.4.3",
    "@opentui/react": "0.4.3",
    "react": "19.2.7",
    "react-devtools-core": "7.0.1",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17",
    "@types/ws": "8.18.1",
    "typescript": "6.0.3"
  }
}
