{
  "name": "@matheusbbarni/kitten",
  "version": "0.6.1",
  "description": "Kitten - Cross-Agent Hand-off Cockpit: a terminal cockpit that hands a live coding task between AI agents over ACP.",
  "repository": {
    "type": "git",
    "url": "https://github.com/MatheusBBarni/Kitten"
  },
  "type": "module",
  "bin": {
    "kitten": "bin/kitten.mjs"
  },
  "files": [
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "@matheusbbarni/kitten-darwin-arm64": "0.6.1",
    "@matheusbbarni/kitten-darwin-x64": "0.6.1",
    "@matheusbbarni/kitten-linux-arm64": "0.6.1",
    "@matheusbbarni/kitten-linux-x64": "0.6.1"
  },
  "scripts": {
    "start": "bun run --cwd ../.. packages/tui/src/index.ts",
    "dev": "bun run --cwd ../.. packages/tui/src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test --cwd ../.. packages/tui/src src test packages/tui/test",
    "test:coverage": "bun test --cwd ../.. packages/tui/src src test packages/tui/test --coverage --isolate",
    "selfcheck": "bun run --cwd ../.. packages/tui/src/index.ts --self-check",
    "selfcheck:reload": "bun run --cwd ../.. packages/tui/src/index.ts --self-check --reload-probe",
    "build": "bun run --cwd ../.. packages/tui/scripts/build.ts",
    "build:local": "bun run --cwd ../.. packages/tui/scripts/build.ts"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "1.2.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@opentui/core": "0.4.3",
    "@opentui/react": "0.4.3",
    "@xterm/headless": "6.0.0",
    "react": "19.2.7",
    "react-devtools-core": "7.0.1",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@agentclientprotocol/claude-agent-acp": "0.57.0",
    "@agentclientprotocol/codex-acp": "1.1.2",
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17",
    "@types/ws": "8.18.1",
    "typescript": "6.0.3"
  }
}
