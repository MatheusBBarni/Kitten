---
import {
  assertValidShowcaseConfig,
  showcaseConfig,
} from "../config/showcase-config.ts";

assertValidShowcaseConfig(showcaseConfig);

const { site, hero } = showcaseConfig;
---

<!doctype html>
<html lang={site.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={site.description} />
    <title>{site.title}</title>
  </head>
  <body>
    <main id={hero.id}>
      <p>{hero.eyebrow}</p>
      <h1>{hero.heading}</h1>
      <p>{hero.body}</p>
    </main>
  </body>
</html>
