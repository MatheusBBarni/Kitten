---
import { getImage } from "astro:assets";

import Faq from "../components/Faq.astro";
import Hero from "../components/Hero.astro";
import Install from "../components/Install.astro";
import Proof from "../components/Proof.astro";
import Requirements from "../components/Requirements.astro";
import SiteControls from "../components/SiteControls.astro";
import {
  assertValidShowcaseConfig,
  showcaseConfig,
} from "../config/showcase-config.ts";
import kittenIcon from "../../../assets/kitten-icon.png";
import "../styles/site.css";

assertValidShowcaseConfig(showcaseConfig);

const favicon = await getImage({
  src: kittenIcon,
  width: 64,
  height: 64,
  format: "png",
});

const { site, navigation, hero, proof, install, requirements, faq, repository } =
  showcaseConfig;
---

<!doctype html>
<html lang={site.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={site.description} />
    <link rel="icon" type="image/png" sizes="64x64" href={favicon.src} />
    <title>{site.title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <SiteControls
      repository={repository}
      navigation={navigation}
      hero={hero}
      proof={proof}
      install={install}
    />
    <main id="main-content">
      <Hero section={hero} install={install} />
      <Proof section={proof} />
      <Install section={install} />
      <Requirements section={requirements} />
      <Faq section={faq} />
    </main>
  </body>
</html>
