---
import type { ShowcaseConfig } from "../config/showcase-config.ts";
import Section from "./Section.astro";

interface Props {
  section: ShowcaseConfig["requirements"];
}

const { section } = Astro.props;
---

<Section id={section.id} heading={section.heading} body={section.body}>
  <ul class="requirements-list">
    {section.items.map((item) => <li>{item}</li>)}
  </ul>
</Section>
